# ===========================================================
# Flux Panel 环境配置模板
# 使用方式：复制此文件为 .env，填入对应环境的值
#   cp .env.example .env
# .env 文件不进 git，仅作用于当前机器/环境
# ===========================================================

# ──────────────────────────────────────────
# Docker 镜像仓库配置（核心！）
# ──────────────────────────────────────────

# 镜像仓库地址（不含镜像名和 tag）
# 开发环境示例（GitLab Container Registry）：
#   IMAGE_REGISTRY=registry.gitlab.kingsungsz.com/yoga/flux-panel-yoga
# 生产环境示例（私有仓库）：
#   IMAGE_REGISTRY=your-prod-registry.example.com/yoga/flux-panel
IMAGE_REGISTRY=registry.gitlab.kingsungsz.com/yoga/flux-panel-yoga

# 镜像 Tag（由 CI/CD 自动注入，或手动指定）
# 开发环境一般用 dev-<commit-sha> 或 dev-latest
# 生产环境一般用 <commit-sha> 或 v1.x.x
# 若不填，docker-compose 默认使用 latest
IMAGE_TAG=latest

# ──────────────────────────────────────────
# 数据库配置
# ──────────────────────────────────────────
DB_NAME=gost
DB_USER=gost
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ──────────────────────────────────────────
# 应用配置
# ──────────────────────────────────────────
# JWT 签名密钥（随机字符串，越长越安全）
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS

# ──────────────────────────────────────────
# 企业 IAM / 钉钉登录配置
# 说明：
# 1. B / C 环境建议通过这里的环境变量配置，不再把 DingTalk 凭据写入数据库
# 2. 后端运行时规则是：环境变量优先，数据库作为兼容回退
# 3. 若环境变量已设置，后台配置接口会拒绝改写对应键
# 4. DINGTALK_ALLOWED_ORG_IDS 使用 JSON 字符串，例如 ["ding_org_a","ding_org_b"]
# ──────────────────────────────────────────
IAM_AUTH_MODE=hybrid
IAM_LOCAL_ADMIN_ENABLED=true
DINGTALK_OAUTH_ENABLED=
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_CORP_ID=
DINGTALK_REDIRECT_URI=
DINGTALK_ALLOWED_ORG_IDS=[]
DINGTALK_REQUIRED_EMAIL_DOMAIN=

# 端口映射（主机端口）
BACKEND_PORT=6365
FRONTEND_PORT=8080
