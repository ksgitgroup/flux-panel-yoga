# Flux receiver
FLUX_URL=https://flux.example.com
FLUX_INSTANCE_KEY=replace-with-instance-key
FLUX_NODE_TOKEN=replace-with-node-token

# Local 1Panel
PANEL_BASE_URL=https://127.0.0.1:10086
PANEL_API_KEY=replace-with-local-1panel-api-key
PANEL_VERIFY_TLS=false
PANEL_TIMEOUT_MS=8000

# Sync behavior
SYNC_INTERVAL=300
ASSET_BIND_KEY=
SITE_ENVIRONMENT=
EXPORTER_LOG_LEVEL=info
